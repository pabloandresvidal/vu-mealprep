generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  passwordHash  String          @default("")
  partnerId     String?         // Linked partner user ID for shared data
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  profiles      FamilyProfile[]
  recipes       Recipe[]
  mealPlans     MealPlan[]
  schedules     MealPlanSchedule[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model FamilyProfile {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  age                  Int?
  gender               String?  // e.g., "Male", "Female", "Other"
  objective            String   // e.g., "lose weight", "gain muscle"
  dietaryRestrictions  String?  // Optional string
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Recipe {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  servings      Int      @default(2)
  energyLevel   String   // e.g., "Low", "Medium", "High"
  ingredients   String   // JSON stringified array
  miseEnPlace   String   // JSON stringified array
  instructions  String   // JSON stringified array
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MealPlan {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate     DateTime
  endDate       DateTime
  energyLevel   String
  numPeople     Int      @default(2)
  profiles      String   // JSON stringified array of profile IDs
  recipeRefs    String   // JSON stringified array of Recipe assignments
  generatedPlan String?  // JSON stringified optimization results
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MealPlanSchedule {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek     Int      // 0=Sunday, 1=Monday, ... 6=Saturday
  energyLevel   String   @default("Medium")
  daysAhead     Int      @default(7) // Generate plan for this many days ahead
  profileIds    String   // JSON array of profile IDs to include
  active        Boolean  @default(true)
  lastRun       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
